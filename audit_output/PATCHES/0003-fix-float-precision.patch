@@ -185,8 +186,12 @@
     if valor_input == "tudo":
         send_sats = total_sats - fee_sats
     else:
-        send_btc = float(valor_input)
-        send_sats = int(send_btc * 100_000_000)
+        from decimal import Decimal
+        try:
+            send_btc = Decimal(valor_input)
+        except Exception:
+            print("[ERRO] Valor invalido")
