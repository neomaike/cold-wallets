 class RPCProxyHandler(BaseHTTPRequestHandler):
     """Handler HTTP para proxy RPC"""

+    def _check_origin(self):
+        """Verifica se origem e permitida"""
+        origin = self.headers.get('Origin', '')
+        if not origin:
+            return True  # Sem origin = chamada direta (curl, etc)
+        for allowed in ALLOWED_ORIGINS:
+            if origin.startswith(allowed):
+                return True
+        return False
+
+    def _cors_headers(self):
+        """Adiciona headers CORS restritos"""
+        origin = self.headers.get('Origin', 'http://127.0.0.1')
+        for allowed in ALLOWED_ORIGINS:
+            if origin.startswith(allowed):
+                self.send_header('Access-Control-Allow-Origin', origin)
+                return
+        self.send_header('Access-Control-Allow-Origin', 'http://127.0.0.1')
+
     def do_POST(self):
         """Processa requisicao POST (RPC)"""
+        if not self._check_origin():
+            self.send_response(403)
+            self.end_headers()
+            self.wfile.write(b'{"error": "Forbidden origin"}')
+            return
+
         content_length = int(self.headers.get('Content-Length', 0))
         body = self.rfile.read(content_length)
